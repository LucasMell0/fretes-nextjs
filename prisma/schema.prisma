generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id              Int                      @id @default(autoincrement())
  nome            String                   @db.VarChar(100)
  email           String                   @unique @db.VarChar(100)
  senha           String                   @db.VarChar(255)
  tipo            TipoUsuario              @default(USUARIO)
  ativo           Boolean                  @default(true)
  dataCriacao     DateTime                 @default(now()) @map("data_criacao")
  dataAtualizacao DateTime                 @updatedAt @map("data_atualizacao")
  cotacoes        CotacaoLog[]
  cotacoesProdutos CotacaoLogProduto[]
  produtos        Produto[]                @relation("ProdutosUsuario")
  regioes         TransportadoraRegiao[]   @relation("RegioesUsuario")
  transportadoras Transportadora[]         @relation("TransportadorasUsuario")
  integracoes     UsuarioIntegracaoCanal[]

  @@index([ativo])
  @@index([email, ativo])
  @@map("usuarios")
}

model Transportadora {
  id              Int                            @id @default(autoincrement())
  nome            String                         @db.VarChar(200)
  fatorCubagem    Decimal                        @default(300) @map("fator_cubagem") @db.Decimal(10, 4)
  ativo           Boolean                        @default(true)
  dataCriacao     DateTime                       @default(now()) @map("data_criacao")
  dataAtualizacao DateTime                       @updatedAt @map("data_atualizacao")
  margemLucro     Decimal                        @default(0) @map("margem_lucro") @db.Decimal(5, 2)
  usuarioId       Int                            @map("usuario_id")
  cotacoes        CotacaoLog[]
  produtoCubagens ProdutoTransportadoraCubagem[]
  regioes         TransportadoraRegiao[]
  usuario         Usuario                        @relation("TransportadorasUsuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, ativo])
  @@index([ativo])
  @@index([nome, ativo])
  @@map("transportadoras")
}

model TransportadoraRegiao {
  id               Int                              @id @default(autoincrement())
  transportadoraId Int                              @map("transportadora_id")
  nome             String                           @db.VarChar(100)
  cepInicio        String                           @map("cep_inicio") @db.VarChar(9)
  cepFim           String                           @map("cep_fim") @db.VarChar(9)
  ativo            Boolean                          @default(true)
  dataCriacao      DateTime                         @default(now()) @map("data_criacao")
  dataAtualizacao  DateTime                         @updatedAt @map("data_atualizacao")
  usuarioId        Int                              @map("usuario_id")
  kgAdicional      TransportadoraRegiaoKgAdicional?
  precos           TransportadoraRegiaoPreco[]
  taxas            TransportadoraRegiaoTaxa?
  transportadora   Transportadora                   @relation(fields: [transportadoraId], references: [id], onDelete: Cascade)
  usuario          Usuario                          @relation("RegioesUsuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([usuarioId, ativo])
  @@index([transportadoraId, ativo])
  @@index([cepInicio, cepFim])
  @@index([ativo])
  @@map("transportadora_regioes")
}

model TransportadoraRegiaoPreco {
  id                     Int                  @id @default(autoincrement())
  transportadoraRegiaoId Int                  @map("transportadora_regiao_id")
  pesoInicial            Decimal              @map("peso_inicial") @db.Decimal(10, 2)
  pesoFinal              Decimal              @map("peso_final") @db.Decimal(10, 2)
  valor                  Decimal              @db.Decimal(10, 2)
  prazo                  Int
  dataCriacao            DateTime             @default(now()) @map("data_criacao")
  dataAtualizacao        DateTime             @updatedAt @map("data_atualizacao")
  regiao                 TransportadoraRegiao @relation(fields: [transportadoraRegiaoId], references: [id], onDelete: Cascade)

  @@map("transportadora_regiao_precos")
}

model TransportadoraRegiaoKgAdicional {
  id                     Int                  @id @default(autoincrement())
  transportadoraRegiaoId Int                  @unique @map("transportadora_regiao_id")
  valorKgAdicional       Decimal              @map("valor_kg_adicional") @db.Decimal(10, 4)
  dataCriacao            DateTime             @default(now()) @map("data_criacao")
  regiao                 TransportadoraRegiao @relation(fields: [transportadoraRegiaoId], references: [id], onDelete: Cascade)

  @@map("transportadora_regiao_kg_adicional")
}

model TransportadoraRegiaoTaxa {
  id                     Int                  @id @default(autoincrement())
  transportadoraRegiaoId Int                  @unique @map("transportadora_regiao_id")
  freteTipo              TipoTaxa             @default(VALOR) @map("frete_valor_tipo")
  freteValor             Decimal              @default(0) @map("frete_valor") @db.Decimal(10, 4)
  freteMinimo            Decimal              @default(0) @map("frete_valor_minimo") @db.Decimal(10, 2)
  grisTipo               TipoTaxa             @default(PERCENTUAL) @map("gris_tipo")
  grisValor              Decimal              @default(0) @map("gris_valor") @db.Decimal(10, 4)
  grisMinimo             Decimal              @default(0) @map("gris_minimo") @db.Decimal(10, 2)
  despachoTipo           TipoTaxa             @default(VALOR) @map("despacho_tipo")
  despachoValor          Decimal              @default(0) @map("despacho_valor") @db.Decimal(10, 4)
  despachoMinimo         Decimal              @default(0) @map("despacho_minimo") @db.Decimal(10, 2)
  pedagioValor           Decimal              @default(0) @map("pedagio_valor") @db.Decimal(10, 2)
  tasTipo                TipoTaxa             @default(PERCENTUAL) @map("tas_tipo")
  tasValor               Decimal              @default(0) @map("tas_valor") @db.Decimal(10, 4)
  tasMinimo              Decimal              @default(0) @map("tas_minimo") @db.Decimal(10, 2)
  tdaAtivo               Boolean              @default(false) @map("tda_ativo")
  tdaTipo                TipoTaxa             @default(VALOR) @map("tda_tipo")
  tdaValor               Decimal              @default(0) @map("tda_valor") @db.Decimal(10, 4)
  tdaMinimo              Decimal              @default(0) @map("tda_minimo") @db.Decimal(10, 2)
  tdeAtivo               Boolean              @default(false) @map("tde_ativo")
  tdeTipo                TipoTaxa             @default(VALOR) @map("tde_tipo")
  tdeValor               Decimal              @default(0) @map("tde_valor") @db.Decimal(10, 4)
  tdeMinimo              Decimal              @default(0) @map("tde_minimo") @db.Decimal(10, 2)
  trfAtivo               Boolean              @default(false) @map("trf_ativo")
  trfTipo                TipoTaxa             @default(VALOR) @map("trf_tipo")
  trfValor               Decimal              @default(0) @map("trf_valor") @db.Decimal(10, 4)
  trfMinimo              Decimal              @default(0) @map("trf_minimo") @db.Decimal(10, 2)
  seguroFluvialAtivo     Boolean              @default(false) @map("seguro_fluvial_ativo")
  seguroFluvialTipo      TipoTaxa             @default(PERCENTUAL) @map("seguro_fluvial_tipo")
  seguroFluvialValor     Decimal              @default(0) @map("seguro_fluvial_valor") @db.Decimal(10, 4)
  seguroFluvialMinimo    Decimal              @default(0) @map("seguro_fluvial_minimo") @db.Decimal(10, 2)
  trtAtivo               Boolean              @default(false) @map("trt_ativo")
  trtTipo                TipoTaxa             @default(VALOR) @map("trt_tipo")
  trtValor               Decimal              @default(0) @map("trt_valor") @db.Decimal(10, 4)
  trtMinimo              Decimal              @default(0) @map("trt_minimo") @db.Decimal(10, 2)
  suframaAtivo           Boolean              @default(false) @map("suframa_ativo")
  suframaTipo            TipoTaxa             @default(PERCENTUAL) @map("suframa_tipo")
  suframaValor           Decimal              @default(0) @map("suframa_valor") @db.Decimal(10, 4)
  suframaMinimo          Decimal              @default(0) @map("suframa_minimo") @db.Decimal(10, 2)
  dataCriacao            DateTime             @default(now()) @map("data_criacao")
  dataAtualizacao        DateTime             @updatedAt @map("data_atualizacao")
  icms                   Decimal              @default(0) @db.Decimal(5, 2)
  regiao                 TransportadoraRegiao @relation(fields: [transportadoraRegiaoId], references: [id], onDelete: Cascade)

  @@map("transportadora_regiao_taxas")
}

model Produto {
  id                        Int                            @id @default(autoincrement())
  nome                      String                         @db.VarChar(200)
  sku                       String                         @db.VarChar(50)
  peso                      Decimal                        @db.Decimal(10, 4)
  cubagem                   Decimal                        @db.Decimal(10, 6)
  crossDocking              Int                            @default(0) @map("cross_docking")
  estoque                   Int                            @default(0)
  ativo                     Boolean                        @default(true)
  dataCriacao               DateTime                       @default(now()) @map("data_criacao")
  dataAtualizacao           DateTime                       @updatedAt @map("data_atualizacao")
  produtoPaiId              Int?                           @map("produto_pai_id")
  usarDadosPaiParaVariacoes Boolean                        @default(false) @map("usar_dados_pai_para_variacoes")
  usuarioId                 Int                            @map("usuario_id")
  cotacoesProdutos          CotacaoLogProduto[]
  cubagens                  ProdutoTransportadoraCubagem[]
  atributos                 ProdutoVariacao[]
  produtoPai                Produto?                       @relation("ProdutoVariacoes", fields: [produtoPaiId], references: [id], onDelete: Cascade)
  variacoes                 Produto[]                      @relation("ProdutoVariacoes")
  usuario                   Usuario                        @relation("ProdutosUsuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([usuarioId, sku])
  @@index([usuarioId, ativo])
  @@index([produtoPaiId])
  @@index([nome])
  @@index([ativo])
  @@index([sku, ativo])
  @@map("produtos")
}

model ProdutoVariacao {
  id        Int     @id @default(autoincrement())
  produtoId Int     @map("produto_id")
  atributo  String  @db.VarChar(100)
  valor     String  @db.VarChar(200)
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@map("produto_variacoes")
}

model ProdutoTransportadoraCubagem {
  id               Int            @id @default(autoincrement())
  produtoId        Int            @map("produto_id")
  transportadoraId Int            @map("transportadora_id")
  cubagem          Decimal        @db.Decimal(10, 6)
  dataCriacao      DateTime       @default(now()) @map("data_criacao")
  dataAtualizacao  DateTime       @updatedAt @map("data_atualizacao")
  produto          Produto        @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  transportadora   Transportadora @relation(fields: [transportadoraId], references: [id], onDelete: Cascade)

  @@unique([produtoId, transportadoraId])
  @@map("produto_transportadora_cubagem")
}

model CotacaoLog {
  id                     Int                 @id @default(autoincrement())
  cep                    String              @db.VarChar(9)
  origem                 String              @default("MANUAL") @db.VarChar(20)
  marketplace            String?             @db.VarChar(100)
  produtosJson           String              @map("produtos_json")
  resultadoJson          String              @map("resultado_json")
  melhorTransportadoraId Int?                @map("melhor_transportadora_id")
  melhorValor            Decimal?            @map("melhor_valor") @db.Decimal(10, 2)
  melhorPrazo            Int?                @map("melhor_prazo")
  totalTransportadoras   Int                 @default(0) @map("total_transportadoras")
  ipOrigem               String?             @map("ip_origem") @db.VarChar(45)
  userAgent              String?             @map("user_agent")
  usuarioId              Int?                @map("usuario_id")
  dataCotacao            DateTime            @default(now()) @map("data_cotacao")
  transportadora         Transportadora?     @relation(fields: [melhorTransportadoraId], references: [id])
  usuario                Usuario?            @relation(fields: [usuarioId], references: [id])
  produtos               CotacaoLogProduto[]

  @@index([cep])
  @@index([origem])
  @@index([dataCotacao])
  @@index([usuarioId])
  @@index([marketplace])
  @@map("cotacoes_log")
}

model CotacaoLogProduto {
  id           Int        @id @default(autoincrement())
  cotacaoLogId Int        @map("cotacao_log_id")
  produtoId    Int        @map("produto_id")
  produtoNome  String     @map("produto_nome") @db.VarChar(200)
  produtoSku   String     @map("produto_sku") @db.VarChar(50)
  quantidade   Int
  pesoTotal    Decimal    @map("peso_total") @db.Decimal(10, 4)
  usuarioId    Int?       @map("usuario_id")
  cotacao      CotacaoLog @relation(fields: [cotacaoLogId], references: [id], onDelete: Cascade)
  produto      Produto    @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  usuario      Usuario?   @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([cotacaoLogId])
  @@index([produtoId])
  @@index([usuarioId])
  @@map("cotacoes_log_produtos")
}

model CanalIntegracao {
  id                  Int                      @id @default(autoincrement())
  nome                String                   @unique @db.VarChar(100)
  slug                String                   @unique @db.VarChar(50)
  tipo                TipoCanal
  logoUrl             String?                  @map("logo_url")
  endpointPattern     String                   @map("endpoint_pattern") @db.VarChar(255)
  metodosHttp         String[]                 @map("metodos_http")
  payloadExemplo      Json?                    @map("payload_exemplo")
  responseExemplo     Json?                    @map("response_exemplo")
  ativo               Boolean                  @default(true)
  criadoEm            DateTime                 @default(now()) @map("criado_em")
  integracoesUsuarios UsuarioIntegracaoCanal[]

  @@map("canais_integracao")
}

model UsuarioIntegracaoCanal {
  id               Int             @id @default(autoincrement())
  usuarioId        Int             @map("usuario_id")
  canalId          Int             @map("canal_id")
  token            String          @unique @db.VarChar(64)
  ativo            Boolean         @default(true)
  status           String          @default("ativo") @db.VarChar(20)
  config           Json?
  ultimaRequisicao DateTime?       @map("ultima_requisicao")
  totalRequisicoes Int             @default(0) @map("total_requisicoes")
  criadoEm         DateTime        @default(now()) @map("criado_em")
  atualizadoEm     DateTime        @updatedAt @map("atualizado_em")
  accessToken      String?         @map("access_token")
  refreshToken     String?         @map("refresh_token")
  scopes           String?         @map("scopes")
  tokenExpiresAt   DateTime?       @map("token_expires_at")
  logs             IntegracaoLog[]
  canal            CanalIntegracao @relation(fields: [canalId], references: [id], onDelete: Cascade)
  usuario          Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, canalId])
  @@index([ativo])
  @@index([status])
  @@map("usuarios_integracao_canais")
}

model IntegracaoLog {
  id                   BigInt                 @id @default(autoincrement())
  usuarioCanalId       Int                    @map("usuario_canal_id")
  metodo               String                 @db.VarChar(10)
  endpoint             String                 @db.VarChar(255)
  queryParams          Json?                  @map("query_params")
  body                 Json?
  headers              Json?
  ipOrigem             String?                @map("ip_origem") @db.VarChar(45)
  statusCode           Int?                   @map("status_code")
  responseBody         Json?                  @map("response_body")
  tempoProcessamentoMs Int?                   @map("tempo_processamento_ms")
  erro                 String?
  criadoEm             DateTime               @default(now()) @map("criado_em")
  usuarioCanal         UsuarioIntegracaoCanal @relation(fields: [usuarioCanalId], references: [id], onDelete: Cascade)

  @@index([usuarioCanalId])
  @@index([criadoEm])
  @@index([statusCode])
  @@map("integracao_logs")
}

enum TipoUsuario {
  ADMIN   @map("admin")
  USUARIO @map("usuario")

  @@map("tipo_usuario")
}

enum TipoTaxa {
  PERCENTUAL @map("percentual")
  VALOR      @map("valor")

  @@map("tipo_taxa")
}

enum TipoCanal {
  MARKETPLACE
  ERP
  WEBHOOK

  @@map("tipo_canal")
}
